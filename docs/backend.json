
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Profil pengguna sistem (Admin/Staff).",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Book": {
      "title": "Book",
      "type": "object",
      "description": "Data koleksi buku perpustakaan.",
      "properties": {
        "code": { "type": "string" },
        "title": { "type": "string" },
        "accountCode": { "type": "string", "description": "Kode rekening atau anggaran buku." },
        "publisher": { "type": "string" },
        "publicationYear": { "type": "number" },
        "totalStock": { "type": "number" },
        "availableStock": { "type": "number" }
      }
    },
    "LibraryMember": {
      "title": "LibraryMember",
      "type": "object",
      "description": "Data anggota perpustakaan (Siswa/Guru).",
      "properties": {
        "memberId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Student", "Teacher"] },
        "classOrSubject": { "type": "string" },
        "phone": { "type": "string" },
        "joinDate": { "type": "string", "format": "date" }
      },
      "required": ["memberId", "name", "type"]
    },
    "BorrowingTransaction": {
      "title": "BorrowingTransaction",
      "type": "object",
      "description": "Catatan peminjaman buku.",
      "properties": {
        "bookId": { "type": "string" },
        "memberId": { "type": "string" },
        "status": { "type": "string" },
        "condition": { "type": "string", "enum": ["normal", "damaged", "lost"] },
        "borrowDate": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "fineAmount": { "type": "number" }
      }
    },
    "Settings": {
      "title": "Settings",
      "type": "object",
      "description": "Konfigurasi global sistem (Batas Pinjam & Denda).",
      "properties": {
        "loanPeriod": { "type": "number", "description": "Lama pinjam dalam hari." },
        "fineAmount": { "type": "number", "description": "Denda per hari terlambat." },
        "lostBookFine": { "type": "number", "description": "Denda flat jika buku hilang." },
        "libraryName": { "type": "string" },
        "govtInstitution": { "type": "string" },
        "eduDept": { "type": "string" },
        "schoolName": { "type": "string" },
        "schoolAddress": { "type": "string" },
        "reportCity": { "type": "string" },
        "principalName": { "type": "string" },
        "principalNip": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/settings/general": {
      "schema": { "$ref": "#/backend/entities/Settings" },
      "description": "Penyimpanan konfigurasi kebijakan sekolah."
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/backend/entities/Book" },
      "description": "Koleksi buku sekolah."
    },
    "/members/{memberId}": {
      "schema": { "$ref": "#/backend/entities/LibraryMember" },
      "description": "Data anggota perpustakaan."
    },
    "/transactions/{transId}": {
      "schema": { "$ref": "#/backend/entities/BorrowingTransaction" },
      "description": "Riwayat sirkulasi buku."
    }
  }
}
