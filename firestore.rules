
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5 - UPDATE IZIN AKSES
     * Memastikan semua petugas yang login dapat mengelola data sirkulasi.
     * Triggering deployment to fix "Missing or insufficient permissions" on /members list operation.
     * Version: 1.0.2
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profil Pengguna (Petugas/Admin)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Koleksi Anggota (Siswa/Guru) - Explicit permissions to solve list errors
    match /members/{memberId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Transaksi & Sirkulasi
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Pengaturan Sistem
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    // Log Aktivitas & Audit Stok
    match /activity_logs/{logId} {
      allow read, create: if isSignedIn();
    }
  }
}
