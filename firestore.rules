
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANTERA BACA - SECURITY RULES v6.0
     * Keamanan akses data perpustakaan sekolah.
     */

    // 1. Pengaturan Umum: Izin Baca Publik agar identitas sekolah muncul di Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Profil Pengguna: Diperlukan untuk sistem autentikasi dan role
    match /users/{userId} {
      allow read, write: if true;
    }

    // 3. Koleksi Utama (Members, Books, Transactions, Logs)
    // Menggunakan wildcard rekursif agar query list/get berjalan lancar bagi petugas yang login
    match /members/{docId=**} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{docId=**} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{docId=**} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{docId=**} {
      allow read, write: if request.auth != null;
    }

    // 4. Rule Global (Fallback)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
