
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5
     * Pemicu Pembaruan Paksa: 2024-05-21 13:00 UTC
     * Mengizinkan akses penuh untuk pengguna yang terautentikasi.
     */

    // Profil Pengguna (Bisa diakses untuk pendaftaran admin pertama)
    match /users/{userId} {
      allow read, write: if true;
    }

    // Seluruh koleksi lainnya (books, members, transactions, settings, logs)
    // Menggunakan wildcard rekursif untuk memastikan izin 'list' dan 'read' terpenuhi
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Aturan spesifik untuk koleksi utama guna memastikan konsistensi
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }

    match /members/{memberId} {
      allow read, write: if request.auth != null;
    }

    match /books/{bookId} {
      allow read, write: if request.auth != null;
    }
  }
}
