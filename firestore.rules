
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - GLOBAL SECURITY RULES
     * Memberikan izin akses bagi petugas terdaftar.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas sistem
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Pengguna (Users):
    // Izinkan listing terbatas (limit 1) untuk cek inisialisasi admin pertama saat belum login
    match /users {
      allow list: if request.auth == null && request.query.limit <= 1;
      allow list, get, write: if request.auth != null;
    }
    
    // 3. Koleksi Utama (Authenticated Access)
    match /members/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{docId} {
      allow read, write: if request.auth != null;
    }

    // 4. Akses Global Fallback
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
