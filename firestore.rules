
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // AKSES TOTAL: Membuka akses untuk siapa saja tanpa kecuali.
    // Solusi untuk menghilangkan error "Missing or insufficient permissions" secara permanen.
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
