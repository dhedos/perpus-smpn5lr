
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SISTEM PERPUSTAKAAN SMPN 5 - SECURITY RULES V2.0
     * Menghilangkan rekursi dan memperbaiki akses awal.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Pengecekan peran yang aman (Tidak memanggil dirinya sendiri)
    // get(/users/uid) akan memicu aturan 'get' pada koleksi users
    function hasRole(roles) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in roles;
    }

    function isStaff() {
      return hasRole(['Admin', 'Staff']);
    }

    function isAdmin() {
      return hasRole(['Admin']);
    }

    // Koleksi Pengguna (Profil)
    match /users/{userId} {
      // PENTING: User harus bisa membaca profilnya sendiri secara langsung 
      // tanpa pengecekan peran tambahan untuk mencegah infinite recursion.
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Mengizinkan list untuk pengecekkan setup awal (hanya bagi yang sudah login)
      allow list: if isSignedIn();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Koleksi Transaksi
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Koleksi Anggota
    match /members/{memberId} {
      allow read, write: if isStaff();
    }

    // Koleksi Pengaturan
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Log Aktivitas
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isSignedIn();
    }
  }
}
