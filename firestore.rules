
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. IZIN GLOBAL UNTUK PETUGAS TERDAFTAR
    // Menjamin seluruh kueri 'list' dan 'get' pada semua koleksi diizinkan jika sudah login.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // 2. IZIN KHUSUS KOLEKSI UTAMA (Double-Check)
    match /transactions/{id} { allow read, write: if request.auth != null; }
    match /members/{id} { allow read, write: if request.auth != null; }
    match /books/{id} { allow read, write: if request.auth != null; }
    match /activity_logs/{id} { allow read, write: if request.auth != null; }

    // 3. AKSES PUBLIK (Diperlukan untuk inisialisasi & pendaftaran admin pertama)
    match /users/{userId} {
      allow read, write: if true;
    }
    match /settings/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
