
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ATURAN ABSOLUT: Izinkan akses baca (get/list) dan tulis ke SEMUA koleksi
    // bagi siapa pun yang sudah login ke sistem (Petugas/Admin).
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Pengecualian publik untuk proses registrasi admin pertama kali
    match /users/{userId} {
      allow read, write: if true;
    }
    match /settings/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
