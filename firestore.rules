
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANTERA BACA - SECURITY RULES v5.0
     * Keamanan berlapis untuk operasional perpustakaan sekolah.
     */

    // 1. Pengaturan Umum: Izin Baca Publik (untuk memuat Judul/Sub-judul di Login)
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Profil Pengguna: Diperlukan untuk sistem autentikasi dan role
    match /users/{userId} {
      allow read, write: if true;
    }

    // 3. Koleksi Anggota: Izin bagi semua petugas yang login
    match /members/{memberId} {
      allow read, write: if request.auth != null;
    }

    // 4. Koleksi Buku: Izin bagi semua petugas yang login
    match /books/{bookId} {
      allow read, write: if request.auth != null;
    }

    // 5. Koleksi Transaksi: Izin bagi semua petugas yang login
    match /transactions/{transId} {
      allow read, write: if request.auth != null;
    }
    
    // 6. Log Aktivitas & Stock Opname
    match /activity_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // 7. Rule Global (Fallback): Seluruh data lainnya wajib Login
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
