
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5 - FINAL DEPLOYMENT
     * Memberikan izin akses eksplisit untuk semua fitur sirkulasi.
     * Triggering deployment to ensure "Missing or insufficient permissions" is resolved.
     * Version: 1.0.3
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profil Pengguna (Petugas/Admin)
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Koleksi Anggota (Siswa/Guru)
    match /members/{memberId} {
      allow list, get, create, update, delete: if isSignedIn();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Transaksi & Sirkulasi
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Pengaturan Sistem
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    // Log Aktivitas & Audit Stok
    match /activity_logs/{logId} {
      allow read, create: if isSignedIn();
    }
  }
}
