
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANTERA BACA - SECURITY RULES
     * Versi 4.0: Izin publik untuk konfigurasi dasar (Kop & Subtitle)
     */

    // Izin Baca Publik: Diperlukan untuk menampilkan Sub-judul di Login & Loading Screen
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Profil Pengguna: Diperlukan untuk pendaftaran dan login
    match /users/{userId} {
      allow read, write: if true;
    }

    // Rule Global: Seluruh data operasional lainnya wajib Login
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
