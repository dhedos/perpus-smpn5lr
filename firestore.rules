
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SISTEM PERPUSTAKAAN SMPN 5 - SECURITY RULES
     * Diperbarui untuk mencegah rekursi pada pengecekan role.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Fungsi pembantu untuk mengambil data user tanpa memicu rekursi
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isSignedIn() && (getUserData().role == 'Admin' || getUserData().role == 'Staff');
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    // Koleksi Pengguna (Admin/Staff)
    match /users/{userId} {
      // PENTING: User harus bisa membaca dokumennya sendiri tanpa isStaff() 
      // untuk menghindari rekursi saat fungsi isStaff() memanggil get() pada koleksi ini.
      allow get: if isOwner(userId) || (isSignedIn() && getUserData().role in ['Admin', 'Staff']);
      allow list: if isStaff(); 
      allow create: if isSignedIn(); 
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Koleksi Anggota Perpustakaan
    match /members/{memberId} {
      allow read, write: if isStaff();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Koleksi Transaksi (Pinjam & Kembali)
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }

    // Koleksi Log Aktivitas
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Koleksi Pengaturan
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
