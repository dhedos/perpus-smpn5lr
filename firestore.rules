
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Izin Baca Publik untuk Users & Settings (untuk login & inisialisasi admin pertama)
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /users {
      allow list: if true;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 2. Izin Penuh untuk Petugas Terdaftar pada koleksi utama
    // Menggunakan match/{allPaths=**} dan match individual untuk menjamin list/get diizinkan
    match /members {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /books {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /transactions {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }
    
    match /activity_logs {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    // 3. Fallback Global untuk Petugas Terdaftar
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
