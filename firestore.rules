
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SISTEM PERPUSTAKAAN SMPN 5 - SECURITY RULES
     * Versi 1.3 - Optimasi pengecekan peran dan pencegahan rekursi.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi pengecekan role yang aman dan tidak rekursif
    function hasRole(roles) {
      let authPath = /databases/$(database)/documents/users/$(request.auth.uid);
      // exists() dan get() di sini akan divalidasi oleh match /users/{userId}
      return isSignedIn() && exists(authPath) && get(authPath).data.role in roles;
    }

    function isStaff() {
      return hasRole(['Admin', 'Staff']);
    }

    function isAdmin() {
      return hasRole(['Admin']);
    }

    // Koleksi Pengguna (Admin/Staff)
    match /users/{userId} {
      // PENTING: Izin dasar untuk membaca profil sendiri
      // Digunakan sebagai base case agar fungsi get() di rules tidak looping
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Izin administratif untuk melihat daftar petugas lain
      allow list: if isStaff();
      allow get: if isStaff();
      
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Koleksi Transaksi (Pinjam & Kembali)
    match /transactions/{transactionId} {
      // Hanya petugas (Admin/Staff) yang bisa mengelola sirkulasi
      allow read, write: if isStaff();
    }

    // Koleksi Anggota Perpustakaan
    match /members/{memberId} {
      allow read, write: if isStaff();
    }

    // Koleksi Buku
    match /books/{bookId} {
      // Semua user yang login bisa melihat katalog buku
      allow read: if isSignedIn();
      // Hanya petugas yang bisa menambah/ubah buku
      allow write: if isStaff();
    }

    // Koleksi Log Aktivitas
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Koleksi Pengaturan
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
