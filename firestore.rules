
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Aturan Global untuk Pengguna Terotentikasi
    // Petugas (Admin/Staff) yang sudah login memiliki akses penuh
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 2. Akses Publik Terbatas (Untuk proses Inisialisasi/Login)
    match /settings/{docId} {
      allow read: if true;
    }
    
    match /users/{docId} {
      allow read: if true;
    }

    // 3. Izin Eksplisit Koleksi Utama (Mencegah Error List/Query)
    match /transactions/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /members/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
