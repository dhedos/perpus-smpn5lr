
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. ATURAN UTAMA: Izinkan akses penuh (baca & tulis) bagi pengguna terotentikasi.
    // Menggunakan recursive wildcard {allPaths=**} untuk memastikan operasi 'list' 
    // pada koleksi 'transactions' dan lainnya diizinkan bagi petugas terdaftar.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 2. ATURAN PUBLIK: Izinkan baca publik untuk koleksi 'settings' dan 'users'.
    // Ini diperlukan untuk inisialisasi aplikasi dan pengecekan profil admin saat login.
    match /settings/{docId} {
      allow read: if true;
    }
    
    match /users/{docId} {
      allow read: if true;
    }
  }
}
