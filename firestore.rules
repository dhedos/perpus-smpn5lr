
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Aturan Koleksi Utama: Izinkan akses penuh bagi petugas yang sudah login.
    // Menggunakan recursive wildcard pada tingkat koleksi untuk menjamin operasi kueri (list) diizinkan.
    match /{collection}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // 2. Akses Publik Khusus: Diperlukan untuk inisialisasi aplikasi dan pengaturan awal.
    match /settings/{docId} {
      allow read: if true;
    }
    
    match /users/{docId} {
      allow read: if true;
    }
  }
}
