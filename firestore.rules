
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5
     * Memastikan akses terkontrol berdasarkan status login.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profil Pengguna (Petugas/Admin)
    // Diizinkan publik untuk pengecekan setup awal, namun sebaiknya dikunci setelah setup.
    match /users/{userId} {
      allow get, list, create, update, delete: if true;
    }

    // Koleksi Anggota (Siswa/Guru)
    match /members/{memberId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Koleksi Transaksi & Sirkulasi (Peminjaman/Pengembalian)
    // Error sebelumnya terjadi di sini karena permintaan 'list' ditolak.
    match /transactions/{transactionId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Koleksi Pengaturan Sistem
    match /settings/{settingId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Log Aktivitas & Audit Stok
    match /activity_logs/{logId} {
      allow get, list, create: if isSignedIn();
    }
  }
}
