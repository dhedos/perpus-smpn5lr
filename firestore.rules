
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SISTEM PERPUSTAKAAN SMPN 5 - SECURITY RULES FINAL
     * Memperbaiki rekursi dan memberikan akses yang tepat bagi petugas.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Koleksi Pengguna (Profil)
    // Diizinkan membaca profil sendiri tanpa rekursi pengecekan peran
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/users/$(request.auth.uid)));
      allow write: if isSignedIn() && (request.auth.uid == userId || exists(/databases/$(database)/documents/users/$(request.auth.uid)));
    }

    // Koleksi Transaksi
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Koleksi Anggota
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Koleksi Pengaturan (Settings)
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // Log Aktivitas
    match /activity_logs/{logId} {
      allow read, create: if isSignedIn();
    }
  }
}
