
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Izin Baca Publik untuk Users (untuk login & setup)
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /users {
      allow list: if true;
    }

    // 2. Izin Baca Publik untuk Pengaturan Umum
    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 3. Izin Penuh untuk Petugas Terdaftar pada koleksi utama
    match /members/{docId} {
      allow read, write: if isSignedIn();
    }
    match /members {
      allow list: if isSignedIn();
    }
    
    match /books/{docId} {
      allow read, write: if isSignedIn();
    }
    match /books {
      allow list: if isSignedIn();
    }
    
    match /transactions/{docId} {
      allow read, write: if isSignedIn();
    }
    match /transactions {
      allow list: if isSignedIn();
    }
    
    match /activity_logs/{docId} {
      allow read, write: if isSignedIn();
    }
    match /activity_logs {
      allow list: if isSignedIn();
    }

    // 4. Fallback Global
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
