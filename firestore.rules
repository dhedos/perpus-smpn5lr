
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. AKSES PUBLIK: Pengaturan dan Profil Pengguna (untuk inisialisasi login)
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. AKSES PETUGAS (AUTHENTICATED): Koleksi Sirkulasi & Inventaris
    // Izin 'read' mencakup 'get' dan 'list' (kueri)
    match /transactions/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /members/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /books/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /activity_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // 3. GLOBAL CATCH-ALL: Pastikan keamanan menyeluruh bagi petugas terdaftar
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
