
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - EXPLICIT SECURITY RULES
     * Memberikan izin eksplisit per koleksi untuk menjamin kelancaran operasional petugas.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Utama: Akses penuh bagi petugas yang login
    match /members/{memberId} {
      allow read, write, list: if request.auth != null;
    }

    match /books/{bookId} {
      allow read, write, list: if request.auth != null;
    }

    match /transactions/{transId} {
      allow read, write, list: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read, write, list: if request.auth != null;
    }
    
    match /activity_logs/{logId} {
      allow read, write, list: if request.auth != null;
    }

    // 3. Fallback: Tetap mengizinkan akses internal jika sudah login
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
