
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Izin Global: Pengguna yang sudah login memiliki akses penuh ke semua data operasional
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Izin Publik: Diperlukan untuk inisialisasi aplikasi (halaman login/pengaturan awal)
    match /settings/{docId} {
      allow read: if true;
    }
    
    match /users/{docId} {
      allow read: if true;
    }
  }
}
