
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - GLOBAL SECURITY RULES
     * Memberikan izin penuh bagi petugas yang sudah login untuk menjamin kelancaran operasional.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Akses Koleksi Utama: Hanya untuk petugas yang sudah login
    // Menggunakan wildcard {allPaths=**} untuk mencakup semua sub-koleksi dan dokumen
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
