
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Izin Baca Publik untuk Users & Settings (untuk login & inisialisasi)
    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    match /users {
      allow list: if true;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 2. Izin Penuh untuk Petugas Terdaftar pada koleksi utama
    // Menggunakan wildcard {allPaths=**} untuk menjamin akses list/get yang konsisten
    match /members/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /books/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /transactions/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
    
    match /activity_logs/{allPaths=**} {
      allow read, write: if isSignedIn();
    }

    // 3. Fallback Global
    match /{path=**} {
      allow read, write: if isSignedIn();
    }
  }
}
