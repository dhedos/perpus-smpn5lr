
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SISTEM PERPUSTAKAAN SMPN 5 - SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      // Mengambil role dari dokumen user itu sendiri
      return isSignedIn() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }

    function hasRole(role) {
      return isSignedIn() && getRole() == role;
    }

    function isStaff() {
      // Menyesuaikan dengan role yang digunakan di aplikasi (Admin & Staff)
      return hasRole('Admin') || hasRole('Staff');
    }

    function isAdmin() {
      return hasRole('Admin');
    }

    // Koleksi Pengguna (Admin/Staff)
    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff(); 
      allow create: if isSignedIn(); // Izinkan inisialisasi admin pertama atau pendaftaran oleh admin lain
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // Koleksi Anggota Perpustakaan
    match /members/{memberId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Koleksi Transaksi (Pinjam & Kembali)
    match /transactions/{transactionId} {
      allow read: if isStaff();
      allow write: if isStaff();
    }

    // Koleksi Log Aktivitas (Audit & Stock Opname)
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Koleksi Pengaturan (Denda, Batas Pinjam, dll)
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
