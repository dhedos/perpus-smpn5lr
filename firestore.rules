
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANTERA BACA - GLOBAL SECURITY RULES (Optimized)
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas sistem
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Pengguna (Users):
    // Diperlukan untuk deteksi admin pertama dan profil
    match /users/{userId} {
      allow get, list, read: if true;
      allow write: if request.auth != null;
    }
    
    match /users {
      allow list, read: if true;
    }
    
    // 3. Koleksi Utama (Authenticated Access)
    // Berikan izin eksplisit penuh bagi petugas yang sudah login
    match /members/{docId} {
      allow read, write, get, list, create, update, delete: if request.auth != null;
    }
    
    match /books/{docId} {
      allow read, write, get, list, create, update, delete: if request.auth != null;
    }
    
    match /transactions/{docId} {
      allow read, write, get, list, create, update, delete: if request.auth != null;
    }
    
    match /activity_logs/{docId} {
      allow read, write, get, list, create, update, delete: if request.auth != null;
    }

    // 4. Akses Global Fallback
    match /{path=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
