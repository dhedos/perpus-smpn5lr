
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5 LANGKE REMBONG
     * Pemicu Pembaruan Paksa: 2024-05-23 10:00 UTC
     * Mengizinkan akses penuh (read/write) untuk Admin dan Petugas yang telah login.
     */

    // Akses Global: Diperlukan agar query 'list' pada koleksi seperti transactions tidak terhambat
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Aturan khusus per koleksi untuk kejelasan (opsional namun disarankan)
    match /transactions/{transactionId} {
      allow get, list, create, update, delete: if request.auth != null;
    }

    match /members/{memberId} {
      allow get, list, create, update, delete: if request.auth != null;
    }

    match /books/{bookId} {
      allow get, list, create, update, delete: if request.auth != null;
    }

    match /users/{userId} {
      allow get, list, create, update, delete: if true;
    }

    match /settings/{settingId} {
      allow get, list, create, update, delete: if request.auth != null;
    }

    match /activity_logs/{logId} {
      allow get, list, create, update, delete: if request.auth != null;
    }
  }
}
