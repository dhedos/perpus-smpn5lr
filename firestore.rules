
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - SECURITY RULES
     * Memberikan izin akses penuh bagi petugas yang sudah login.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Akses Global untuk Petugas (Books, Members, Transactions, dll)
    // Menggunakan catch-all untuk memastikan tidak ada error 'Missing Permissions' pada list/get
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
