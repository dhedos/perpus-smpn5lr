
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. AKSES PUBLIK: Diperlukan untuk inisialisasi aplikasi dan login
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. AKSES PETUGAS (AUTHENTICATED): Berlaku untuk semua koleksi utama
    // Menggunakan recursive wildcard untuk menjamin operasi 'list' dan 'get' diizinkan
    match /transactions/{id=**} {
      allow read, write: if request.auth != null;
    }

    match /members/{id=**} {
      allow read, write: if request.auth != null;
    }

    match /books/{id=**} {
      allow read, write: if request.auth != null;
    }

    match /activity_logs/{id=**} {
      allow read, write: if request.auth != null;
    }

    // 3. GLOBAL CATCH-ALL: Pastikan tidak ada celah keamanan bagi pengguna luar
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
