
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Izin Akses Koleksi Utama: Izinkan baca (get/list) dan tulis bagi petugas terdaftar.
    // Menggunakan recursive wildcard {document=**} untuk memastikan operasi kueri (list) diizinkan.
    
    match /transactions/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /members/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /books/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /activity_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Settings & User Profiles: Baca diizinkan publik untuk inisialisasi, tulis butuh login.
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Aturan Cadangan Global untuk Keamanan
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
