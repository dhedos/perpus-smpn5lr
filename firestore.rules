
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. IZIN UTAMA: Izinkan SEMUA akses (baca/tulis) ke SELURUH koleksi 
    // jika pengguna telah login ke sistem.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // 2. IZIN SPESIFIK TRANSAKSI: Menjamin operasi 'list' (kueri daftar) 
    // tidak terhambat oleh aturan global.
    match /transactions {
      allow read, write: if request.auth != null;
    }
    match /transactions/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // 3. AKSES PUBLIK: Diperlukan untuk proses pendaftaran Admin pertama kali
    // dan pengambilan konfigurasi judul perpustakaan di halaman login.
    match /users/{userId} {
      allow read, write: if true;
    }
    match /settings/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
