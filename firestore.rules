
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SMPN 5 LANGKE REMBONG - SECURITY RULES
     * Versi Stabil: 3.0 (Reset ke izin global untuk Admin & Petugas)
     */

    // Rule Global: Mengizinkan akses baca dan tulis bagi seluruh personil yang telah login.
    // Ini mencakup get, list, create, update, dan delete.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Rule Khusus Profil: Diperlukan untuk proses registrasi awal/google login
    match /users/{userId} {
      allow read, write: if true;
    }
  }
}
