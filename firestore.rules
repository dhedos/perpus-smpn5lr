
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - SECURITY RULES
     * Memberikan izin akses berdasarkan status login petugas.
     */

    // 1. Pengaturan Umum: Baca publik agar identitas sekolah muncul di Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Profil Pengguna: Diperlukan untuk inisialisasi dan role
    match /users/{userId} {
      allow read, write: if true;
    }

    // 3. Koleksi Operasional: Wajib login untuk semua aksi (List, Get, Create, Update, Delete)
    // Mencakup: members, books, transactions, activity_logs
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
