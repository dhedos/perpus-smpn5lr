
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5 - UPDATED FOR INITIAL SETUP
     * Mengizinkan akses baca/tulis pada koleksi users agar setup admin pertama berjalan lancar.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profil Pengguna (Petugas/Admin) - Diizinkan publik untuk pengecekan setup awal
    match /users/{userId} {
      allow read, write: if true;
    }

    // Koleksi Anggota (Siswa/Guru)
    match /members/{memberId} {
      allow list, get, create, update, delete: if isSignedIn();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Transaksi & Sirkulasi
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn();
    }

    // Koleksi Pengaturan Sistem
    match /settings/{settingId} {
      allow read, write: if isSignedIn();
    }

    // Log Aktivitas & Audit Stok
    match /activity_logs/{logId} {
      allow read, create: if isSignedIn();
    }
  }
}
