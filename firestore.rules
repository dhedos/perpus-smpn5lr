
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - SECURITY RULES
     * Memberikan izin akses eksplisit untuk setiap koleksi utama.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Profil Pengguna & Data Petugas
    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // 3. Koleksi Operasional: Izin bagi petugas yang login
    // Menggunakan wildcard {document=**} untuk mencakup akses list (collection) dan get (document)
    
    match /members/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Aturan Global Cadangan
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
