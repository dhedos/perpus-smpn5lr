
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - SECURITY RULES
     * Memberikan izin akses penuh bagi petugas yang sudah login.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Utama (Books, Members, Transactions, Activity Logs)
    // Diizinkan baca (list/get) dan tulis (create/update/delete) jika sudah terautentikasi.
    match /books/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /members/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 3. Akses Global Fallback (Opsional untuk koleksi masa depan)
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
