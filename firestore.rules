
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SMPN 5 LANGKE REMBONG - SECURITY RULES
     * Versi Update: 2.0 (Pemicu Redeploy: 2024-05-23 11:30 UTC)
     * Mengizinkan akses baca dan tulis bagi seluruh personil yang telah login.
     */

    // Rule Global: Mengizinkan akses get, list, create, update, delete bagi user yang login
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Rule Khusus Profil: Diperlukan untuk proses registrasi awal/google login
    match /users/{userId} {
      allow read, write: if true;
    }

    // Rule Khusus Koleksi: Memastikan list operation (pencarian) tidak terblokir
    match /transactions/{id} {
      allow read, write: if request.auth != null;
    }
    
    match /members/{id} {
      allow read, write: if request.auth != null;
    }

    match /books/{id} {
      allow read, write: if request.auth != null;
    }

    match /settings/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
