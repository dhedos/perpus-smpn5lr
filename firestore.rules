
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN LANTERA BACA - GLOBAL SECURITY RULES
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas sistem
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Pengguna (Users):
    // Izinkan baca publik untuk deteksi inisialisasi admin dan pengecekan profil saat logout
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users {
      allow list: if true;
    }
    
    // 3. Koleksi Utama (Authenticated Access)
    // Diberikan izin eksplisit untuk list, get, create, update, delete bagi petugas terdaftar
    match /members/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{docId} {
      allow read, write: if request.auth != null;
    }

    // 4. Akses Global Fallback
    match /{path=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
