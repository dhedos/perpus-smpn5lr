
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - GLOBAL SECURITY RULES
     * Memberikan izin akses bagi petugas yang sudah login untuk menjamin kelancaran operasional.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Akses Global untuk Petugas Terautentikasi
    // Ini mencakup koleksi: members, books, transactions, users, dan activity_logs
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
