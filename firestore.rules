
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Aturan Global untuk Pengguna Terotentikasi
    // Memberikan izin baca dan tulis ke seluruh koleksi bagi petugas yang sudah login
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 2. Aturan Terbuka Khusus (Wajib untuk proses Login/Inisialisasi)
    match /settings/{docId} {
      allow read: if true;
    }
    
    match /users/{docId} {
      allow read: if true;
    }

    // 3. Aturan Eksplisit Koleksi Utama (Double-Safety)
    match /transactions/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /members/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
