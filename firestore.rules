
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * LANTERA BACA - SECURITY RULES v7.0
     * Keamanan akses data perpustakaan sekolah.
     */

    // 1. Pengaturan Umum: Izin Baca Publik agar identitas sekolah muncul di Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Profil Pengguna: Diperlukan untuk sistem autentikasi dan role
    match /users/{userId} {
      allow read, write: if true;
    }

    // 3. Koleksi Utama (Members, Books, Transactions, Logs)
    // Menggunakan wildcard eksplisit untuk koleksi dan dokumen
    match /members {
      allow read, write: if request.auth != null;
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /books {
      allow read, write: if request.auth != null;
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /transactions {
      allow read, write: if request.auth != null;
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    match /activity_logs {
      allow read, write: if request.auth != null;
      match /{allPaths=**} {
        allow read, write: if request.auth != null;
      }
    }

    // 4. Rule Global (Fallback)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
