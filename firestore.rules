
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. IZIN UTAMA: Izinkan akses baca (get/list) dan tulis 
    // ke SELURUH dokumen bagi pengguna yang sudah login.
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // 2. AKSES PUBLIK: Diperlukan untuk inisialisasi aplikasi 
    // dan pendaftaran admin pertama kali.
    match /users/{userId} {
      allow read, write: if true;
    }
    match /settings/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
