
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ATURAN KEAMANAN PERPUSTAKAAN SMPN 5
     * Force Update Trigger: 2024-05-21 09:15 UTC (Explicit list permissions)
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Profil Pengguna (Petugas/Admin)
    match /users/{userId} {
      allow get, list, create, update, delete: if true;
    }

    // Koleksi Anggota (Siswa/Guru)
    match /members/{memberId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Koleksi Transaksi & Sirkulasi (Peminjaman/Pengembalian)
    // Dibuat sangat eksplisit untuk menghindari error 'list'
    match /transactions/{transactionId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Koleksi Pengaturan Sistem
    match /settings/{settingId} {
      allow get, list, create, update, delete: if isSignedIn();
    }

    // Log Aktivitas & Audit Stok
    match /activity_logs/{logId} {
      allow get, list, create, update, delete: if isSignedIn();
    }
  }
}
