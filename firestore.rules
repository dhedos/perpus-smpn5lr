rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SCHOOL LIBRARY SYSTEM SECURITY RULES
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a hybrid Role-Based Access Control (RBAC) and Ownership model.
     * It prioritizes "Authorization Independence" by leveraging denormalized identifiers 
     * (like userId and memberUserId) to permit high-performance security checks without 
     * excessive cross-document lookups.
     */

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function getRole() {
      return isSignedIn() ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }

    function hasRole(role) {
      return isSignedIn() && getRole() == role;
    }

    function isStaff() {
      return hasRole('Admin') || hasRole('Officer');
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the User collection.
     * allow list: if true; -> Diperlukan agar halaman login bisa mendeteksi apakah sistem sudah memiliki admin (inisialisasi).
     */
    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if true; 
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if false; 
    }

    match /library_members/{memberId} {
      allow get: if isStaff() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 10); 
      allow create, update, delete: if isStaff();
    }

    match /book_categories/{categoryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /shelf_locations/{locationId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /books/{bookId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isStaff();
    }

    match /borrowing_transactions/{transactionId} {
      allow get: if isStaff() || (isSignedIn() && resource.data.memberUserId == request.auth.uid);
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 50);
      allow create, update, delete: if isStaff();
    }

    match /activity_logs/{logId} {
      allow get, list: if hasRole('Admin');
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false; 
    }

    match /overdue_notifications/{notificationId} {
      allow get: if isStaff() || (isSignedIn() && resource.data.memberUserId == request.auth.uid);
      allow list: if isStaff() || (isSignedIn() && request.query.limit <= 20);
      allow create, update, delete: if isStaff();
    }

    // Allow staff to manage settings
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
    
    // Allow managing members collection (from previous request)
    match /members/{memberId} {
      allow read, write: if isStaff();
    }

    // Allow managing transactions collection
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }
  }
}