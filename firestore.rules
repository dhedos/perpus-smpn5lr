
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - GLOBAL SECURITY RULES
     * Memberikan izin akses penuh bagi petugas yang sudah login (Authenticated).
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Akses Koleksi Utama (Eksplisit untuk mencegah error Permission Denied)
    match /members/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /users/{docId} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{docId} {
      allow read, write: if request.auth != null;
    }

    // 3. Akses Global Fallback
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
