
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SISTEM PERPUSTAKAAN SMPN 5 - SECURITY RULES
     * Memperbaiki rekursi dengan memisahkan izin akses profil sendiri.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Fungsi untuk mendapatkan role tanpa memicu rekursi berlebih
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff() {
      return isSignedIn() && getUserRole() in ['Admin', 'Staff'];
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'Admin';
    }

    // Koleksi Pengguna (Admin/Staff)
    match /users/{userId} {
      // PENTING: User bisa membaca datanya sendiri secara langsung (Base Case)
      // Ini mencegah rekursi saat fungsi getUserRole() memanggil get()
      allow get: if isSignedIn() && request.auth.uid == userId;
      
      // Admin/Staff bisa melihat profil user lain
      allow get, list: if isStaff();
      
      allow create: if isSignedIn(); 
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Koleksi Anggota Perpustakaan
    match /members/{memberId} {
      allow read, write: if isStaff();
    }

    // Koleksi Buku
    match /books/{bookId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // Koleksi Transaksi (Pinjam & Kembali)
    match /transactions/{transactionId} {
      allow read, write: if isStaff();
    }

    // Koleksi Log Aktivitas
    match /activity_logs/{logId} {
      allow read: if isStaff();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Koleksi Pengaturan
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }
  }
}
