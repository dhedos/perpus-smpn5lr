
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - SECURITY RULES
     * Memberikan izin akses bagi petugas yang login.
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Akses Global untuk Petugas: Mengizinkan read/write pada semua koleksi utama jika sudah login
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
