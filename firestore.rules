
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * PERPUSTAKAAN SEKOLAH - EXPLICIT SECURITY RULES
     * Memastikan izin eksplisit untuk menghindari error "Missing or insufficient permissions"
     */

    // 1. Pengaturan Umum: Bisa dibaca publik untuk identitas di halaman Login
    match /settings/general {
      allow get, list: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Anggota (Members)
    match /members/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

    // 3. Koleksi Buku (Books)
    match /books/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

    // 4. Koleksi Transaksi (Transactions)
    match /transactions/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

    // 5. Koleksi Log Aktivitas (Activity Logs)
    match /activity_logs/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

    // 6. Koleksi Pengguna (Users)
    match /users/{docId} {
      allow list, get, create, update, delete: if request.auth != null;
    }

    // 7. Fallback Global untuk mengantisipasi path lain
    match /{path=**} {
      allow read, write: if request.auth != null;
    }
  }
}
