
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Aturan untuk Pengaturan Sistem & Pengguna
    // Menggunakan recursive wildcard {allPaths=**} untuk memastikan semua sub-dokumen tercover
    match /settings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /users/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. Koleksi Utama Sistem
    // Izin diberikan secara eksplisit untuk read (get & list) serta write bagi user terotentikasi
    
    match /members/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /books/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /transactions/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    match /activity_logs/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 3. Fallback Global
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
